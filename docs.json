{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "appearance": {"default": "light", "strict": false},
  "name": "Parsagon API",
  "colors": {
    "primary": "#006ef5",
    "light": "#006ef5",
    "dark": "#006ef5"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": [
          "api-reference/introduction"
        ]
      },
      {
        "group": "Endpoints",
        "pages": [
          "api-reference/endpoint/quick-search",
          "api-reference/endpoint/advanced-search",
          "api-reference/endpoint/get-search",
          "api-reference/endpoint/category-sources"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:webmaster@parsagon.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://parsagon.io/create-alert"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "claude",
     "chatgpt",
     "perplexity"
   ]
  },
  "api": {
    "playground": {
      "display": "none"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/api-reference/introduction"
    }
  ],
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/parsagon/"
    }
  }
}
